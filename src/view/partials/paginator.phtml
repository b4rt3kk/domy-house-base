<?php
/* @var $paginator \Base\Paginator */
if ($paginator instanceof \Base\Paginator) {
    if (!$paginator->getIsInitialized()) {
        $paginator->init();
    }

    $viewConfig = $paginator->getViewConfig();

    $ajaxUrl = $viewConfig->getAjaxUrl() ?? $this->url('ajax', ['action' => 'paginator']);
    $storageContainerName = $paginator->getStorageContainerName();
    $paginatorId = $paginator->getPaginatorId();
    $tableActionsPartial = $viewConfig->getTableActionsPartial();
    $listPartial = $viewConfig->getListPartial();
    
    $form = $paginator->getFilterForm();

    if ($form instanceof \Base\Form\AbstractForm && $viewConfig->getShowFilter()) {
        echo '<div class="paginator-filter mb-4">';
        echo $this->partial($viewConfig->getFilterPartial(), ['form' => $form, 'paginator' => $paginator]);
        echo '</div>';
    }

    $totalResults = $paginator->getTotalResults();

    if ($totalResults > 0) {
        $data = $paginator->getData();

        echo '<div id="' . $paginatorId . '">';

        if ($viewConfig->getShowTopNavigation()) {
            echo $this->partial($viewConfig->getTopNavigationPartial(), ['paginator' => $paginator]);
        }

        echo $this->partial($listPartial, [
            'paginator' => $paginator,
            'data' => $data,
            'headers' => $paginator->getHeaders(),
            'index' => $paginator->getItemsPerPage() * ($paginator->getCurrentPage() - 1) + 1,
            'responsive' => $viewConfig->getIsResponsive(),
            'table_actions_partial' => $tableActionsPartial,
            'ajax_url' => $ajaxUrl,
            'ajax_params' => json_encode(['paginatorId' => $paginatorId]),
            'sort' => $paginator->getSortingData(),
        ]);

        if ($viewConfig->getShowBottomNavigation()) {
            echo $this->partial($viewConfig->getBottomNavigationPartial(), ['paginator' => $paginator]);
        }
        
        echo '</div>';
    } else {
        echo $this->translate($viewConfig->getNoResultsText());
    }
    
    $this->inlineScript()->captureStart();
echo <<<"JS"
    $('#{$paginatorId}').find('select[name="items_per_page"]').on("change", function() {
        let itemsPerPage = $(this).val();
        $(this).prop('disabled', true);
        $(this).closest('nav').find('.paginator-loader').show();
    
        $.ajax({
            url: '{$ajaxUrl}',
            type: "POST",
            data: {paginatorId: '{$paginatorId}', itemsPerPage: itemsPerPage},
            success: function(response) {
                window.location.reload(true);
            }
        });
    });
JS;
    $this->inlineScript()->captureEnd();
}
